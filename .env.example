APPLITOOLS_API_KEY=YOUR_APPLITOOLS_API_KEY_HERE

LT_USERNAME=LT_USERNAME_HERE
LT_ACCESS_KEY=LT_ACCESS_KEY_HERE

# Upload each app to LambdaTest and paste the returned lt:// URL here.
# Set LT_APP_URL to whichever app you want to run before executing a script.
LT_APP_ANALYTICSX=
LT_APP_ACCESSIBILITY=

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility

# --- iOS device (wdio.ios.lambdatest.conf.js) ---
DEVICE_NAME=iPhone 14
PLATFORM_VERSION=17

# --- Android device (wdio.android.lambdatest.conf.js) ---
# LT_APP_URL=$LT_APP_ANALYTICSX  (then run: npm run android:analyticsx)
# DEVICE_NAME=Samsung Galaxy S23
# PLATFORM_VERSION=13

# --- Android device on Sauce Labs (wdio.android.saucelabs.conf.js) ---
SAUCE_USERNAME=SAUCE_USERNAME_HERE
SAUCE_ACCESS_KEY=SAUCE_ACCESS_KEY_HERE
# us-west-1 (default) | eu-central-1 | etc.
SAUCE_REGION=us-west-1

# Upload each app to Sauce Labs app storage and paste the returned storage:filename=... or storage:<id> reference here.
SAUCE_APP_ANALYTICSX=storage:filename=PASTE_ANALYTICSX_APK_HERE
SAUCE_APP_ACCESSIBILITY=storage:filename=PASTE_ACCESSIBILITY_APK_HERE

# --- Android device on Perfecto (wdio.android.perfecto.conf.js) ---
# Your Perfecto cloud subdomain, e.g. "demo" for demo.perfectomobile.com
PERFECTO_CLOUD_NAME=PERFECTO_CLOUD_NAME_HERE
PERFECTO_SECURITY_TOKEN=PERFECTO_SECURITY_TOKEN_HERE

# Upload each app to the Perfecto media repository and paste the returned repository path here,
# e.g. PERFECTO:REPOSITORY:PUBLIC:AnalyticsX.apk
PERFECTO_APP_ANALYTICSX=PERFECTO:REPOSITORY:PASTE_ANALYTICSX_APK_HERE
PERFECTO_APP_ACCESSIBILITY=PERFECTO:REPOSITORY:PASTE_ACCESSIBILITY_APK_HERE

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
