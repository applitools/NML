APPLITOOLS_API_KEY=your_applitools_api_key

LT_USERNAME=your_lt_username
LT_ACCESS_KEY=your_lt_access_key

# Upload each app to LambdaTest and paste the returned lt:// URL here.
# Set LT_APP_URL to whichever app you want to run before executing a script.
LT_APP_ANALYTICSX=lt://APP_PASTE_ANALYTICSX_URL_HERE
LT_APP_ACCESSIBILITY=lt://APP_PASTE_ACCESSIBILITY_URL_HERE

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility

# --- iOS device (wdio.ios.lambdatest.conf.ts) ---
DEVICE_NAME=iPhone 16
PLATFORM_VERSION=18

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
