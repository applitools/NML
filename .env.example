APPLITOOLS_API_KEY=your_applitools_api_key

LT_USERNAME=your_lt_username
LT_ACCESS_KEY=your_lt_access_key

# Upload each app to LambdaTest and paste the returned lt:// URL here.
# Set LT_APP_URL to whichever app you want to run before executing a script.
LT_APP_ANALYTICSX=
ANALYTICSX_APP_PACKAGE=com.applitools.analyticsx
ANALYTICSX_APP_ACTIVITY=com.applitools.analyticsx.MainActivity

LT_APP_ACCESSIBILITY=
ACCESSIBILITY_APP_PACKAGE=com.applitools.accessibilitytest
ACCESSIBILITY_APP_ACTIVITY=com.applitools.accessibilitytest.MainActivity


# Set to "analyticsx" or "accessibility" — auto-selects the matching app url,
# package, activity, and spec file
ACTIVE_APP=accessibility

# --- Android device (wdio.android.lambdatest.conf.ts) ---
 DEVICE_NAME=Galaxy S26
 PLATFORM_VERSION=16

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
