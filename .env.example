APPLITOOLS_API_KEY=YOUR_API_KEY_HERE
PERFECTO_CLOUD_NAME=PERFECTO_CLOUD_NAME_HERE
PERFECTO_SECURITY_TOKEN=PERFECTO_SECURITY_TOKEN_HERE

# Upload each .ipa to the Perfecto media repository and paste the returned repository path here,
# e.g. PERFECTO:REPOSITORY:PUBLIC:AnalyticsX.ipa
PERFECTO_APP_ANALYTICSX=PUBLIC:AnalyticsXUIKit.ipa
PERFECTO_APP_ACCESSIBILITY=PUBLIC:AccessibilityTestUIKit.ipa

# Set to "analyticsx" or "accessibility" — auto-selects the matching app url and spec file
ACTIVE_APP=accessibility


# --- added: device/app overrides ---
DEVICE_NAME=
PLATFORM_VERSION=

# AnalyticsX flow: compact | full  (default: full)
FLOW=full
