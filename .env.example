# ── Applitools ────────────────────────────────────────────────
APPLITOOLS_API_KEY=YOUR_API_KEY_HERE
EYES_APP_NAME=NML iOS Sample
EYES_BATCH_NAME=NML iOS Local Tests

# ── Appium ────────────────────────────────────────────────────
APPIUM_URL=http://127.0.0.1:4723

# ── Device / Simulator ────────────────────────────────────────
DEVICE_NAME=iPhone 16
DEVICE_UDID=YOUR_SIMULATOR_UDID_HERE
PLATFORM_VERSION=18.0

# ── Test 1 · Accessibility App ────────────────────────────────
# Point to the .app bundle under SampleApplication/
ACCESSIBILITY_APP_PATH=SampleApplication/Applitcation1-accessibility-app/IOS Native/UI Kit/Simulator/AccessibilityTestUIKit.app
ACCESSIBILITY_BUNDLE_ID=com.applitools.AccessibilityTestUIKit

# ── Test 2 · AnalyticsX App ───────────────────────────────────
ANALYTICSX_APP_PATH=SampleApplication/Application2-analyticsx-app/IOS Native/UIKit/Emulator/AnalyticsXUIKit-Simulator.app
ANALYTICSX_BUNDLE_ID=com.applitools.AnalyticsXUIKit
