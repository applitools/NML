<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:paddingBottom="32dp">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- HERO CARD                                       -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/navy_900"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Eyebrow -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hero_eyebrow"
                    android:textColor="@color/hero_eyebrow"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textAllCaps="true"
                    android:accessibilityHeading="true" />

                <!-- Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/hero_title"
                    android:textColor="@color/white"
                    android:textSize="34sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"
                    android:accessibilityHeading="true" />

                <!-- Badge row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <!-- Badge: Current text size -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:background="@drawable/bg_size_badge"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_text_size_label"
                            android:textColor="@color/hero_eyebrow"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvTextSizeLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Default"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Badge: Font scale -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5dp"
                        android:background="@drawable/bg_size_badge"
                        android:orientation="vertical"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/badge_font_scale_label"
                            android:textColor="@color/hero_eyebrow"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:textAllCaps="true" />

                        <TextView
                            android:id="@+id/tvFontScaleValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="1.00x"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Subtitle -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/hero_subtitle"
                    android:textColor="@color/hero_subtitle"
                    android:textSize="17sp"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- METRIC PANEL                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/metricPanel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="18dp"
                android:contentDescription="">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_font_scale"
                        android:textColor="@color/gray_700"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMetricFontScale"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1.00x"
                        android:textColor="@color/blue_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metric_checklist"
                        android:textColor="@color/gray_700"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMetricChecklist"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="1/4"
                        android:textColor="@color/blue_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- READING SAMPLE CARD                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_reading_sample"
                    android:textColor="@color/gray_900"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"
                    android:accessibilityHeading="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/reading_sample_body"
                    android:textColor="@color/gray_700"
                    android:textSize="17sp"
                    android:lineSpacingMultiplier="1.4" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/reading_sample_tip"
                    android:textColor="@color/gray_500"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.3" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- BASIC TEST CHECKLIST                            -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_checklist"
                    android:textColor="@color/gray_900"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"
                    android:accessibilityHeading="true" />

                <!-- Checklist item: Font scaling (initially checked) -->
                <LinearLayout
                    android:id="@+id/rowFont"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_check_row_selected"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:accessibilityLiveRegion="polite"
                    android:contentDescription="Font scaling. Increase system font size and confirm text wraps cleanly. Checked">

                    <FrameLayout
                        android:id="@+id/cbFont"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_checkbox_selected">

                        <TextView
                            android:id="@+id/checkMarkFont"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✓"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Font scaling"
                            android:textColor="@color/gray_900"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Increase system font size and confirm text wraps cleanly."
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Checklist item: Screen reader -->
                <LinearLayout
                    android:id="@+id/rowReader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_check_row_normal"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Screen reader. Use TalkBack to check labels, roles, and state. Not checked">

                    <FrameLayout
                        android:id="@+id/cbReader"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_checkbox_normal">

                        <TextView
                            android:id="@+id/checkMarkReader"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✓"
                            android:textColor="@android:color/transparent"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Screen reader"
                            android:textColor="@color/gray_900"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Use VoiceOver or TalkBack to check labels, roles, and state."
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Checklist item: Contrast -->
                <LinearLayout
                    android:id="@+id/rowContrast"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_check_row_normal"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Contrast. Confirm selected, disabled, and body text remain readable. Not checked">

                    <FrameLayout
                        android:id="@+id/cbContrast"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_checkbox_normal">

                        <TextView
                            android:id="@+id/checkMarkContrast"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✓"
                            android:textColor="@android:color/transparent"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contrast"
                            android:textColor="@color/gray_900"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Confirm selected, disabled, and body text remain readable."
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Checklist item: Touch targets -->
                <LinearLayout
                    android:id="@+id/rowTouch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_check_row_normal"
                    android:minHeight="64dp"
                    android:orientation="horizontal"
                    android:padding="14dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Touch targets. Buttons and controls should remain easy to tap at large text. Not checked">

                    <FrameLayout
                        android:id="@+id/cbTouch"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:background="@drawable/bg_checkbox_normal">

                        <TextView
                            android:id="@+id/checkMarkTouch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="✓"
                            android:textColor="@android:color/transparent"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:importantForAccessibility="no" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="14dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Touch targets"
                            android:textColor="@color/gray_900"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Buttons and controls should remain easy to tap at large text."
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- INPUT AND CONTROLS                              -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_input"
                    android:textColor="@color/gray_900"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"
                    android:accessibilityHeading="true" />

                <!-- Tester name label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_tester_name"
                    android:textColor="@color/gray_800"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Tester name input -->
                <EditText
                    android:id="@+id/etTesterName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input"
                    android:hint="@string/hint_tester_name"
                    android:inputType="textCapWords|textPersonName"
                    android:minHeight="52dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:textColor="@color/gray_900"
                    android:textColorHint="@color/gray_500"
                    android:textSize="17sp"
                    android:contentDescription="Tester name. Enter the name used for this accessibility test" />

                <!-- Enable reminders row -->
                <LinearLayout
                    android:id="@+id/switchRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_reminders"
                            android:textColor="@color/gray_800"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/caption_reminders"
                            android:textColor="@color/gray_500"
                            android:textSize="14sp"
                            android:lineSpacingMultiplier="1.3" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/switchReminders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:contentDescription="Enable reminders. Turns accessibility test reminders on or off" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- TEST PRIORITY                                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/gray_200"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/section_priority"
                    android:textColor="@color/gray_900"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:lineSpacingExtra="2dp"
                    android:accessibilityHeading="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/priority_body"
                    android:textColor="@color/gray_700"
                    android:textSize="17sp"
                    android:lineSpacingMultiplier="1.4" />

                <!-- Priority toggle group -->
                <LinearLayout
                    android:id="@+id/priorityGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnPriorityStandard"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_segment_normal"
                        android:minHeight="48dp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="10dp"
                        android:text="@string/priority_standard"
                        android:textColor="@color/gray_700"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:contentDescription="Standard priority" />

                    <Button
                        android:id="@+id/btnPriorityLargeText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/bg_segment_selected"
                        android:minHeight="48dp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="10dp"
                        android:text="@string/priority_large_text"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:contentDescription="Large text priority" />

                    <Button
                        android:id="@+id/btnPriorityScreenReader"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:background="@drawable/bg_segment_normal"
                        android:minHeight="48dp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="10dp"
                        android:text="@string/priority_screen_reader"
                        android:textColor="@color/gray_700"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:stateListAnimator="@null"
                        android:contentDescription="Screen reader priority" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- ACTION BUTTONS                                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStartTest"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_button_primary"
                android:minHeight="52dp"
                android:paddingHorizontal="18dp"
                android:paddingVertical="12dp"
                android:text="@string/btn_start_test"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:contentDescription="Start accessibility test" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
